# Exemplo de .env para o backend
# Copie este arquivo para .env e preencha com seus valores reais.
SPRING_APPLICATION_NAME=pet_link
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<database>?sslmode=require
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_SHOW_SQL=true
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB
SPRING_JACKSON_TIME_ZONE=America/Sao_Paulo
JWT_EXPIRATION=900000
JWT_SECRET=<jwt-secret>
